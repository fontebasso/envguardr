{
  "name": "envguardr",
  "description": "Catch broken env vars before your app starts — fail-fast CLI with strict schema validation.",
  "keywords": [
    "cli",
    "env",
    "environment-variables",
    "validation",
    "schema",
    "typescript",
    "ci",
    "devops",
    "dotenv",
    "fail-fast"
  ],
  "version": "2.0.0",
  "private": false,
  "type": "module",
  "author": "Samuel Fontebasso",
  "license": "MIT",
  "scripts": {
    "build": "node build.mjs && tsc -p tsconfig.build.json",
    "format": "prettier --write ./src ./tests",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "validate": "tsx bin/cli.ts validate ./tests/fixtures/env.schema.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "bin": {
    "envguardr": "./dist/bin/cli.js"
  },
  "files": [
    "dist/"
  ],
  "directories": {
    "test": "tests"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fontebasso/envguardr.git"
  },
  "bugs": {
    "url": "https://github.com/fontebasso/envguardr/issues"
  },
  "homepage": "https://github.com/fontebasso/envguardr#readme",
  "dependencies": {
    "valitype": "2.0.2"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.5",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
