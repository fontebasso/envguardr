{
  "name": "envguardr",
  "description": "Fail-fast environment variable validation for Node.js, CI/CD, and bad deploy prevention.",
  "keywords": [
    "cli",
    "nodejs",
    "env",
    "dotenv",
    "process-env",
    "environment",
    "environment-variables",
    "validation",
    "validator",
    "schema",
    "config",
    "runtime-config",
    "typescript",
    "javascript",
    "ci",
    "cd",
    "cicd",
    "devops",
    "docker",
    "fail-fast"
  ],
  "version": "3.1.2",
  "private": false,
  "type": "module",
  "author": "Samuel Fontebasso",
  "license": "MIT",
  "scripts": {
    "build": "node build.mjs && tsc -p tsconfig.build.json",
    "format": "prettier --write ./src ./tests",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "validate": "tsx bin/cli.ts validate ./tests/fixtures/env.schema.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "fuzz:validate-env": "npm run build && npx jazzer --sync fuzz/validate-env.fuzz.js -- -runs=10000",
    "fuzz:custom-validators": "npm run build && npx jazzer --sync fuzz/validate-env-custom-validators.fuzz.js -- -runs=10000",
    "fuzz:schema": "npm run build && npx jazzer --sync fuzz/validate-env-schema.fuzz.js -- -runs=10000",
    "fuzz:edge-cases": "npm run build && npx jazzer --sync fuzz/validate-env-edge-cases.fuzz.js -- -runs=10000",
    "fuzz:validate-env:run": "npx jazzer --sync fuzz/validate-env.fuzz.js -- -runs=10000",
    "fuzz:custom-validators:run": "npx jazzer --sync fuzz/validate-env-custom-validators.fuzz.js -- -runs=10000",
    "fuzz:schema:run": "npx jazzer --sync fuzz/validate-env-schema.fuzz.js -- -runs=10000",
    "fuzz:edge-cases:run": "npx jazzer --sync fuzz/validate-env-edge-cases.fuzz.js -- -runs=10000",
    "fuzz": "npm run build && npm run fuzz:validate-env:run && npm run fuzz:custom-validators:run && npm run fuzz:schema:run && npm run fuzz:edge-cases:run"
  },
  "bin": {
    "envguardr": "./dist/bin/cli.js"
  },
  "files": [
    "dist/"
  ],
  "directories": {
    "test": "tests"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^22.0.0 || ^24.0.0 || ^26.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fontebasso/envguardr.git"
  },
  "bugs": {
    "url": "https://github.com/fontebasso/envguardr/issues"
  },
  "homepage": "https://github.com/fontebasso/envguardr#readme",
  "dependencies": {
    "valitype": "3.0.0"
  },
  "devDependencies": {
    "@jazzer.js/core": "^4.0.0",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.5",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
